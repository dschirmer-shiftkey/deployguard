{
  "name": "@deployguard/mcp-server",
  "version": "3.0.0",
  "private": true,
  "description": "MCP server exposing DeployGuard health checks and risk scoring as tools",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "deployguard-mcp": "dist/server.js"
  },
  "scripts": {
    "prebuild": "node -e \"const fs=require('fs');fs.copyFileSync('../src/risk-engine.ts','src/risk-engine.ts');fs.mkdirSync('src/adapters',{recursive:true});['types','registry','vercel','supabase','aws-ecs','fly-io','cloudflare','index'].forEach(f=>fs.copyFileSync('../src/adapters/'+f+'.ts','src/adapters/'+f+'.ts'))\"",
    "build": "tsc",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
