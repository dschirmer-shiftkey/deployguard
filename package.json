{
  "name": "trailhead",
  "version": "3.0.2",
  "private": true,
  "description": "Deployment gate for GitHub PRs — scores code risk, checks production health, integrates security signals, and blocks dangerous releases.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/KomatikAI/trailhead.git"
  },
  "homepage": "https://github.com/KomatikAI/trailhead#readme",
  "bugs": {
    "url": "https://github.com/KomatikAI/trailhead/issues"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/main.ts -o dist --source-map --license licenses.txt",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . && tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dev": "tsx watch src/main.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/github": "^9.1.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.0",
    "@vercel/ncc": "^0.38.4",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "tsx": "^4.22.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.4"
  }
}
